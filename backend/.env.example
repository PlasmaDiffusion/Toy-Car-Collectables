# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_CONFIG=development        # development | production | testing
SECRET_KEY=replace-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (local dev)
DATABASE_URL=postgresql://postgres:password@localhost:5432/diecast_vault

# Examples for hosted providers — see db-notes.md for full breakdown:
# Supabase (free tier):
#   DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Neon (free tier):
#   DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/diecast_vault?sslmode=require

# Railway:
#   DATABASE_URL=postgresql://postgres:[password]@[host].railway.app:5432/railway

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000

# ── Testing ───────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=sqlite:///:memory:
